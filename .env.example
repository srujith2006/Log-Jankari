# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-secret-key

# MongoDB Atlas Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/DisasterSurvivorSystem?retryWrites=true&w=majority&appName=<app-name>
MONGO_DB_NAME=DisasterSurvivorSystem

# Server Configuration
HOST=0.0.0.0
PORT=5000
WEB_SERVER_PORT=8000
GPS_SERVER_PORT=8888
GPS_REQUEST_TIMEOUT_SECONDS=0.2
USE_MONGO=1
STARTUP_MONGO=0
RECORD_OUTPUT_VIDEO=0
SURVIVOR_SAVE_INTERVAL_SECONDS=1.0
DETECTION_FRAME_SKIP=2
PROCESS_FRAME_WIDTH=640
CAMERA_READ_FAILURE_LIMIT=20

# Camera Configuration
# Use your IP Webcam stream URL, or VIDEO_URL=0 for the default laptop/USB webcam.
VIDEO_URL=0

# Detection Configuration
YOLO_MODEL=yolov8n-pose.pt
PERSON_CONFIDENCE=0.65
PERSON_IOU=0.45
MIN_PERSON_BOX_AREA=2500
SURVIVOR_FOLDER=survivors

# Optional Gemini analysis for PDF-only disaster history and cause summary.
# Put the real key in .env, never commit it.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
